    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.10",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.0",
    "pdfmake": "^0.3.11",
    "pg": "^8.21.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1"
