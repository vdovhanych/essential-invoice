{
  "name": "essential-invoice-backend",
  "version": "1.0.0",
  "description": "Self-hosted invoicing application backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.6.6",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "pg": "^8.11.3",
    "pdfmake": "^0.2.18",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/imap": "^0.8.40",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mailparser": "^3.4.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfmake": "^0.2.9",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^3.1.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3",
    "vitest": "^3.1.0"
  },
  "pnpm": {
    "overrides": {
      "semver@<7.0.0": "^7.7.0",
      "lodash@<4.17.23": "^4.17.23",
      "esbuild@<0.25.0": "^0.25.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
