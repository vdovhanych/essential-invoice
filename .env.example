# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=essential_invoice
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Application
JWT_SECRET=your_jwt_secret_here_min_32_chars_recommended
CORS_ORIGIN=http://localhost

# Ports (optional, defaults shown)
BACKEND_PORT=3001
FRONTEND_PORT=80

# Email Polling (milliseconds, default 5 minutes)
EMAIL_POLLING_INTERVAL=300000

# AI Features (Perplexity API)
# Get your API key from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# SMTP Settings (configured via UI, but can be set here)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_email_password
# SMTP_FROM_EMAIL=invoices@example.com
# SMTP_FROM_NAME=Your Company Name

# IMAP Settings for Bank Notifications (configured via UI)
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=your_email@example.com
# IMAP_PASSWORD=your_email_password
