# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=essential_invoice
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Application
JWT_SECRET=your_jwt_secret_here_min_32_chars_recommended
# Encryption key for secrets at rest (SMTP/IMAP passwords, API keys)

# Replace this with your own encryption key. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=aee02347fb6401e6d1c5d3c068d1a2f2873cd7263629a297abf6b999bb568068

# CORS_ORIGIN: Allowed origins for CORS (comma-separated for multiple)
# For Docker/production: http://localhost:8080 or your production domain, also supports multiple origins separated by commas
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Ports (optional, defaults shown)
BACKEND_PORT=3001
FRONTEND_PORT=8080

# Email Polling (milliseconds, default 15 minutes)
EMAIL_POLLING_INTERVAL=900000

# Global SMTP Configuration (for system emails: welcome, password reset)
# These are separate from per-user SMTP settings configured in the app UI
GLOBAL_SMTP_HOST=
GLOBAL_SMTP_PORT=587
GLOBAL_SMTP_USER=
GLOBAL_SMTP_PASSWORD=
GLOBAL_SMTP_SECURE=false
GLOBAL_SMTP_FROM_EMAIL=noreply@yourdomain.com
GLOBAL_SMTP_FROM_NAME=essentialInvoice

# Frontend URL (used for constructing password reset links in emails)
# Docker compose: http://localhost:8080, Kubernetes: your ingress URL
FRONTEND_URL=http://localhost:8080

# Per-user SMTP Settings (configured via UI per user)
# Per-user IMAP Settings for Bank Notifications (configured via UI per user)