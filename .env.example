# Database
DATABASE_URL=postgresql+psycopg2://invoice:invoice@db:5432/invoice

# Auth
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=1440

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=invoice@example.com
SMTP_PASSWORD=secret
SMTP_USE_TLS=true
SMTP_FROM=invoice@example.com

# IMAP
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=invoice@example.com
IMAP_PASSWORD=secret
IMAP_SENDER_PATTERN=noreply@airbank.cz
IMAP_POLL_INTERVAL_SECONDS=300

# ARES
ARES_BASE_URL=https://ares.gov.cz/ekonomicke-subjekty-v-be/rest
