# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=essential_invoice
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Application
JWT_SECRET=your_jwt_secret_here_min_32_chars_recommended
# CORS_ORIGIN: Allowed origins for CORS (comma-separated for multiple)
# For local dev with Vite: http://localhost:5173
# For Docker/production: http://localhost:8080 or your production domain
# Example with multiple: http://localhost:5173,http://localhost:8080
CORS_ORIGIN=http://localhost:5173

# Ports (optional, defaults shown)
BACKEND_PORT=3001
FRONTEND_PORT=80

# Email Polling (milliseconds, default 15 minutes)
EMAIL_POLLING_INTERVAL=900000

# SMTP Settings (configured via UI per user)
# IMAP Settings for Bank Notifications (configured via UI per user)